---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import CareerSection from '../components/CareerSection.astro';
import ProjectsSection from '../components/ProjectsSection.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
import { fetchProjects, fetchProfile, fetchHomePage, fetchAboutPage } from '../lib/api';

const profile = await fetchProfile();
const homePage = await fetchHomePage();
const aboutPage = await fetchAboutPage();
const projects = await fetchProjects();

// Parse Lexical AST to HTML for Career block (Pulled from about.astro logic)
let parsedAboutHtml = '<p class="text-text-muted italic">I am a passionate developer who builds dynamic performant projects.</p>';
if (aboutPage?.content?.root?.children) {
  parsedAboutHtml = aboutPage.content.root.children.map((node: any) => {
    if (node.type === 'paragraph') {
      const text = node.children?.map((c: any) => c.text).join('') || '';
      return `<p class="mb-4 text-text-muted leading-relaxed">${text}</p>`;
    }
    if (node.type === 'heading') {
      const text = node.children?.map((c: any) => c.text).join('') || '';
      return `<h${node.tag} class="text-2xl font-heading font-bold mt-8 mb-4 text-text">${text}</h${node.tag}>`;
    }
    return '';
  }).join('');
}

// Extract SEO fields from Payload SEO plugin
const seoTitle = homePage?.meta?.title || (profile?.name ? `${profile.name} - Portfolio` : 'Portfolio');
const seoDescription = homePage?.meta?.description || homePage?.heroDescription;
const seoImage = homePage?.meta?.image?.url ? `http://localhost:3000${homePage.meta.image.url}` : undefined;
---

<Layout title={seoTitle} description={seoDescription} metaImage={seoImage}>
  <Header />
  
  <main class="relative z-10 w-full overflow-hidden">
    <!-- 1. Home Section -->
    <Hero 
      headline={homePage?.heroHeadline || "Building Digital Solutions"}
      bio={homePage?.heroDescription || "I'm a developer focusing on creating interactive, high-performance web applications."}
      profilePicture={homePage?.profilePicture?.url ? `http://localhost:3000${homePage.profilePicture.url}` : null}
    />
    
    <!-- 2. Career / About Section -->
    <CareerSection 
      title={aboutPage?.title}
      subtitle={aboutPage?.subtitle}
      richTextHtml={parsedAboutHtml}
    />

    <!-- 3. Projects Section -->
    <ProjectsSection 
      title={homePage?.projectsTitle}
      projects={projects}
    />

    <!-- 4. Contact Section -->
    <ContactSection 
      profile={profile}
    />
  </main>
  
  <Footer />

  <!-- Intersection Observer to trigger revealIn animations -->
  <script>
    function setupRevealAnimations() {
      const elements = document.querySelectorAll('.reveal-content');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            // Apply animation if it has not already played
            (entry.target as HTMLElement).style.animationPlayState = 'running';
            observer.unobserve(entry.target);
          }
        });
      }, {
        threshold: 0.1, 
        rootMargin: '0px 0px -50px 0px' 
      });

      elements.forEach(el => {
        // Pause by default so they only run when scrolled into view
        (el as HTMLElement).style.animationPlayState = 'paused';
        observer.observe(el);
      });
    }

    document.addEventListener('DOMContentLoaded', setupRevealAnimations);
  </script>
</Layout>
