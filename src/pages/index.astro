---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { fetchProjects, fetchProfile } from '../lib/api';

const profile = await fetchProfile();
const projects = await fetchProjects();
// Get top 3 latest projects for the home page
const featuredProjects = projects.slice(0, 3);
---

<Layout title={profile?.name ? `${profile.name} - Portfolio` : 'Portfolio'}>
  <Header />
  
  <main class="relative z-10">
    <Hero 
      headline={profile?.heroHeadline}
      bio={profile?.bio}
    />
    
    <section id="projects" class="py-24 max-w-6xl mx-auto px-6">
      <div class="flex justify-between items-end mb-12">
        <div>
          <h2 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">Selected Work</h2>
          <p class="text-text-muted text-lg">A showcase of my recent side projects and development exploits.</p>
        </div>
        <a href="/projects" class="hidden md:inline-flex items-center gap-2 text-primary hover:text-white transition-colors font-medium">
          View all projects →
        </a>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredProjects.map((project: any) => (
          <ProjectCard 
            title={project.title}
            slug={project.slug}
            techStack={project.techStack}
            featuredImage={project.featuredImage}
          />
        ))}
        {featuredProjects.length === 0 && (
          <div class="col-span-full py-20 text-center glass rounded-2xl">
            <p class="text-text-muted">No projects found. Add some from the CMS!</p>
          </div>
        )}
      </div>
      
      <div class="mt-8 text-center md:hidden">
        <a href="/projects" class="inline-flex py-3 px-6 glass rounded-full items-center gap-2 font-medium hover:bg-white/10 transition-colors">
          View all projects →
        </a>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
