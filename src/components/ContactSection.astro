---
interface Props {
  profile: any;
}
const { profile } = Astro.props;
---

<section
  id="contact"
  class="section-container relative min-h-[50vh] flex flex-col justify-center items-center text-center scroll-mt-32"
>
  <div class="reveal-content mb-10" style="animation-delay: 100ms;">
    <h2
      class="text-4xl md:text-5xl font-heading font-black tracking-tight text-text mb-4"
    >
      Contactez-moi
    </h2>
    <div class="h-1 w-24 bg-primary mx-auto mt-6 rounded-full"></div>
  </div>

  <div
    class="reveal-content max-w-2xl mx-auto glass rounded-3xl p-8 md:p-12 w-full"
    style="animation-delay: 300ms;"
  >
    <p class="font-body text-text-muted mb-8 text-lg">
      Je suis actuellement disponible pour des projets freelance en one-shot. Je
      suis apte à vous conseiller sur vos projets et à vous aider à les
      réaliser. N'hésitez pas à me contacter.
    </p>

    <div class="flex flex-wrap justify-center gap-6">
      {
        profile?.email && (
          <a
            href={`mailto:${profile.email}`}
            class="px-8 py-4 rounded-full bg-primary hover:bg-primary/90 text-white font-semibold transition-all hover:scale-105 active:scale-95 flex items-center gap-2 shadow-[0_0_20px_rgba(139,92,246,0.3)]"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              />
            </svg>
            Say Hello
          </a>
        )
      }

      {
        profile?.githubLink && (
          <a
            href={profile.githubLink}
            target="_blank"
            class="p-4 rounded-full glass hover:bg-slate-100 text-text transition-all hover:scale-110 shadow-sm"
            aria-label="GitHub"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path
                fill-rule="evenodd"
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                clip-rule="evenodd"
              />
            </svg>
          </a>
        )
      }

      {
        profile?.linkedinLink && (
          <a
            href={profile.linkedinLink}
            target="_blank"
            class="p-4 rounded-full glass hover:bg-slate-100 text-text transition-all hover:scale-110 shadow-sm"
            aria-label="LinkedIn"
          >
            <svg
              class="w-6 h-6"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                clip-rule="evenodd"
              />
            </svg>
          </a>
        )
      }

      {
        profile?.youtubeLink && (
          <a
            href={profile.youtubeLink}
            target="_blank"
            class="p-4 rounded-full glass hover:bg-slate-100 text-text transition-all hover:scale-110 shadow-sm hover:text-red-500"
            aria-label="YouTube"
          >
            <svg
              class="w-7 h-7 -m-0.5"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M11.996 4C7.036 4 4 4.095 4 4.095C4 4.095 2 4.331 2 6.5C2 7.72 2 12.001 2 12.001C2 12.001 2 16.279 2 17.5C2 19.668 4 19.905 4 19.905C4 19.905 7.036 20 11.996 20C16.953 20 20 19.905 20 19.905C20 19.905 22 19.668 22 17.5C22 16.279 22 12.001 22 12.001C22 12.001 22 7.72 22 6.5C22 4.331 20 4.095 20 4.095C20 4.095 16.953 4 11.996 4ZM9.957 15.419V8.58L15.932 12L9.957 15.419Z"
              />
            </svg>
          </a>
        )
      }

      {
        profile?.twitchLink && (
          <a
            href={profile.twitchLink}
            target="_blank"
            class="p-4 rounded-full glass hover:bg-slate-100 text-text transition-all hover:scale-110 shadow-sm hover:text-purple-500"
            aria-label="Twitch"
          >
            <svg
              class="w-6 h-6"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6.429 2.143 2.143 6.428V20h5.143v4.286l4.285-4.286h3.429L22 13.57V2.143zM20.286 12.714l-3.429 3.429H12L8.571 18.714v-2.571H4.714V3.857h15.572z"
              />
            </svg>
          </a>
        )
      }
    </div>
  </div>
</section>
