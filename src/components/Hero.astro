---
interface Props {
  headline: string;
  bio: string;
}
const { headline, bio } = Astro.props;
---

<section class="min-h-[80vh] flex flex-col justify-center items-center text-center px-6 pt-20">
  <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass mb-8 animate-fade-in-up">
    <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
    <span class="text-sm font-medium text-text-muted">Software Developer</span>
  </div>
  
  <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-8 max-w-4xl leading-tight">
    {headline || "Building Digital Solutions"} <br class="hidden md:block"/>
    <span class="text-gradient">With Passion.</span>
  </h1>
  
  <p class="text-lg md:text-xl text-text-muted max-w-2xl mb-12 leading-relaxed">
    {bio || "I'm a developer focusing on creating interactive, high-performance web applications and side projects that solve real problems."}
  </p>
  
  <div class="flex flex-col sm:flex-row gap-4">
    <a href="#projects" class="px-8 py-4 rounded-full bg-primary hover:bg-primary/90 text-white font-semibold transition-all hover:scale-105 active:scale-95 shadow-[0_0_40px_-10px_rgba(139,92,246,0.5)]">
      View My Work
    </a>
    <a href="https://github.com" target="_blank" class="px-8 py-4 rounded-full glass hover:bg-white/10 text-white font-semibold transition-all hover:scale-105 active:scale-95 flex items-center justify-center gap-2">
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
      </svg>
      GitHub
    </a>
  </div>
</section>
