---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  slug: string;
  techStack: { technology: string }[];
  featuredImage?: { url: string; alt?: string };
}

const { title, slug, techStack, featuredImage } = Astro.props;
---

<a href={`/projects/${slug}`} class="block group">
  <article class="glass rounded-2xl overflow-hidden card-hover h-full flex flex-col items-start bg-gradient-to-b from-surface/80 to-surface/40">
    <div class="relative w-full aspect-video overflow-hidden bg-slate-100 border-b border-slate-200/50">
      {featuredImage?.url ? (
        <Image 
          src={`http://localhost:3000${featuredImage.url}`} 
          alt={featuredImage.alt || title}
          inferSize={true}
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary/10 to-secondary/10">
          <span class="text-slate-400 text-sm font-medium">No Image</span>
        </div>
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-surface via-transparent to-transparent opacity-60"></div>
    </div>
    
    <div class="p-6 flex flex-col gap-4 w-full flex-grow">
      <h3 class="text-xl font-bold text-text group-hover:text-primary transition-colors">{title}</h3>
      
      {techStack && techStack.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-auto">
          {techStack.map((tech) => (
            <span class="px-3 py-1 rounded-full text-xs font-medium bg-slate-100 text-text border border-slate-200">
              {tech.technology}
            </span>
          ))}
        </div>
      )}
    </div>
  </article>
</a>
