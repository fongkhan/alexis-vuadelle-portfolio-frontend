---

---

<header
  id="navbar-island"
  class="fixed top-6 left-1/2 -translate-x-1/2 z-50 transition-all duration-300 flex flex-col items-center justify-between px-6 sm:px-8 py-3 sm:py-4 rounded-[2rem] glass border border-slate-200/50 shadow-[0_8px_30px_rgb(0,0,0,0.06)] w-[90%] sm:w-auto max-w-5xl"
>
  <div class="flex items-center justify-between w-full gap-8 md:gap-16">
    <a
      href="/"
      class="text-xl md:text-2xl font-bold tracking-tighter hover:opacity-80 transition-opacity whitespace-nowrap"
    >
      <span class="text-text">Alexis</span><span class="text-primary">.dev</span>
    </a>
    
    <!-- Desktop Nav -->
    <nav class="hidden md:flex gap-6 lg:gap-8 items-center">
      <a href="#home" class="text-sm font-medium text-text-muted hover:text-text transition-colors whitespace-nowrap">Accueil</a>
      <a href="#projects" class="text-sm font-medium text-text-muted hover:text-text transition-colors whitespace-nowrap">Projets</a>
      <a href="#career" class="text-sm font-medium text-text-muted hover:text-text transition-colors whitespace-nowrap">À propos</a>
      <a href="#contact" class="px-5 py-2.5 rounded-full bg-primary hover:bg-primary/90 text-white text-sm font-medium transition-all hover:scale-105 active:scale-95 shadow-[0_0_15px_rgba(139,92,246,0.3)] ml-2 whitespace-nowrap">Contactez-moi</a>
    </nav>

    <!-- Mobile Hamburger Button -->
    <button id="mobile-menu-btn" class="md:hidden text-text p-2 -mr-2 focus:outline-none" aria-label="Toggle Menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile Dropdown Nav -->
  <nav id="mobile-menu" class="hidden flex-col gap-6 w-full pt-6 pb-4 md:hidden border-t border-slate-200/50 mt-4 text-center">
    <a href="#home" class="mobile-link text-base font-medium text-text-muted hover:text-text transition-colors block">Accueil</a>
    <a href="#projects" class="mobile-link text-base font-medium text-text-muted hover:text-text transition-colors block">Projets</a>
    <a href="#career" class="mobile-link text-base font-medium text-text-muted hover:text-text transition-colors block">À propos</a>
    <a href="#contact" class="mobile-link mt-2 mx-auto max-w-fit px-8 py-3 rounded-full bg-primary text-white text-sm font-medium shadow-[0_0_15px_rgba(139,92,246,0.3)]">Contactez-moi</a>
  </nav>
</header>

<script>
  // Mobile Menu Logic
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  function toggleMenu() {
    menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex');
    hamburgerIcon?.classList.toggle('hidden');
    document.getElementById('close-icon')?.classList.toggle('hidden');
  }

  btn?.addEventListener('click', toggleMenu);

  // Close menu when clicking a link
  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (!menu?.classList.contains('hidden')) {
        toggleMenu();
      }
    });
  });
</script>
